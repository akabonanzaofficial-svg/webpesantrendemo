<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pesantren Modern Al-Hikmah</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Google Fonts: Poppins for modern typography -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- FontAwesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Tailwind Configuration -->
    <script>
        window.tailwind = window.tailwind || {};
        window.tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Poppins', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            50: '#ecfdf5',
                            100: '#d1fae5',
                            500: '#10b981',
                            700: '#047857',
                            900: '#064e3b', // Deep Emerald
                        },
                        gold: {
                            400: '#fbbf24',
                            500: '#f59e0b',
                            600: '#d97706',
                        }
                    }
                }
            }
        }
    </script>

    <style>
        /* Custom Styles & Animations */
        body {
            font-family: 'Poppins', sans-serif;
            overflow-x: hidden;
        }
        
        .hero-pattern {
            background-color: #064e3b;
            background-image: linear-gradient(rgba(6, 78, 59, 0.85), rgba(6, 78, 59, 0.95)), url('https://images.unsplash.com/photo-1584551246679-0daf3d275d0f?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
        }

        /* Scroll Animation Classes */
        .fade-in-up {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.8s ease-out, transform 0.8s ease-out;
        }
        
        .fade-in-up.visible {
            opacity: 1;
            transform: translateY(0);
        }

        .glass-nav {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-800">

    <!-- Navigation -->
    <nav id="navbar" class="fixed w-full z-50 transition-all duration-300 glass-nav shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-20">
                <!-- Logo -->
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-brand-900 flex items-center justify-center text-white font-bold text-xl shadow-lg">
                        <i class="fa-solid fa-moon"></i>
                    </div>
                    <div>
                        <h1 class="font-bold text-xl text-brand-900 leading-tight">Al-Hikmah</h1>
                        <p class="text-xs text-slate-500 font-medium">Pesantren Modern</p>
                    </div>
                </div>

                <!-- Desktop Menu -->
                <div class="hidden md:flex items-center space-x-8">
                    <a href="#beranda" class="text-slate-700 hover:text-brand-700 font-medium transition">Beranda</a>
                    <a href="#profil" class="text-slate-700 hover:text-brand-700 font-medium transition">Profil</a>
                    <a href="#program" class="text-slate-700 hover:text-brand-700 font-medium transition">Program</a>
                    <a href="#fasilitas" class="text-slate-700 hover:text-brand-700 font-medium transition">Fasilitas</a>
                    <a href="#pendaftaran" class="text-slate-700 hover:text-brand-700 font-medium transition">PSB</a>
                    <a href="#berita" class="text-slate-700 hover:text-brand-700 font-medium transition">Berita</a>
                    <a href="#pendaftaran" class="bg-brand-900 hover:bg-brand-700 text-white px-6 py-2.5 rounded-full font-medium transition shadow-lg shadow-brand-900/30">
                        Daftar Sekarang
                    </a>
                </div>

                <!-- Mobile Menu Button -->
                <div class="md:hidden flex items-center">
                    <button id="mobile-menu-btn" class="text-slate-700 hover:text-brand-900 focus:outline-none">
                        <i class="fa-solid fa-bars text-2xl"></i>
                    </button>
                </div>
            </div>
        </div>

        <!-- Mobile Menu Panel -->
        <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-slate-100 absolute w-full shadow-xl">
            <div class="px-4 pt-2 pb-6 space-y-1">
                <a href="#beranda" class="block px-3 py-3 text-slate-700 font-medium border-b border-slate-50">Beranda</a>
                <a href="#profil" class="block px-3 py-3 text-slate-700 font-medium border-b border-slate-50">Profil</a>
                <a href="#program" class="block px-3 py-3 text-slate-700 font-medium border-b border-slate-50">Program</a>
                <a href="#fasilitas" class="block px-3 py-3 text-slate-700 font-medium border-b border-slate-50">Fasilitas</a>
                <a href="#pendaftaran" class="block px-3 py-3 text-slate-700 font-medium border-b border-slate-50">PSB</a>
                <a href="#berita" class="block px-3 py-3 text-slate-700 font-medium border-b border-slate-50">Berita</a>
                <a href="#pendaftaran" class="block px-3 py-3 mt-4 text-center bg-brand-900 text-white rounded-lg font-medium">Daftar Sekarang</a>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section id="beranda" class="hero-pattern min-h-[90vh] flex items-center relative pt-20">
        <!-- Decorative subtle pattern overlay -->
        <div class="absolute inset-0 opacity-10 bg-[radial-gradient(#fff_1px,transparent_1px)] [background-size:20px_20px]"></div>
        
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
            <div class="max-w-3xl fade-in-up">
                <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 backdrop-blur-sm border border-white/20 text-gold-400 text-sm font-medium mb-6">
                    <i class="fa-solid fa-star text-xs"></i> Pendaftaran Santri Baru 2026/2027 Dibuka
                </div>
                <h1 class="text-4xl md:text-6xl font-bold text-white leading-tight mb-6">
                    Membentuk Generasi <span class="text-transparent bg-clip-text bg-gradient-to-r from-gold-400 to-yellow-200">Qur'ani</span> yang Mandiri & Berprestasi
                </h1>
                <p class="text-lg md:text-xl text-brand-50 mb-10 leading-relaxed font-light max-w-2xl">
                    Sistem pendidikan modern yang memadukan kurikulum nasional dan kepesantrenan untuk melahirkan pemimpin masa depan yang berakhlak mulia.
                </p>
                <div class="flex flex-col sm:flex-row gap-4">
                    <a href="#pendaftaran" class="px-8 py-4 bg-gold-500 hover:bg-gold-600 text-brand-900 font-bold rounded-full text-center transition-all transform hover:-translate-y-1 shadow-lg shadow-gold-500/30">
                        Informasi Pendaftaran
                    </a>
                    <a href="#profil" class="px-8 py-4 bg-white/10 hover:bg-white/20 backdrop-blur-md border border-white/30 text-white font-medium rounded-full text-center transition-all flex items-center justify-center gap-2">
                        <i class="fa-solid fa-play text-sm"></i> Video Profil
                    </a>
                </div>
            </div>
        </div>
        
        <!-- Curved bottom shape divider -->
        <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-none">
            <svg class="relative block w-full h-[50px] md:h-[100px]" data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
                <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C59.71,118.08,130.83,123.82,200,111.4,242.66,103.73,283.47,84.4,321.39,56.44Z" fill="#f8fafc"></path>
            </svg>
        </div>
    </section>

    <!-- Profil & Statistik Section -->
    <section id="profil" class="py-20 bg-slate-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid lg:grid-cols-2 gap-16 items-center">
                
                <!-- Images Matrix -->
                <div class="relative fade-in-up">
                    <div class="grid grid-cols-2 gap-4">
                        <img src="https://images.unsplash.com/photo-1577896851231-70ef18881754?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Kegiatan Belajar" class="rounded-2xl shadow-lg w-full h-64 object-cover transform translate-y-8">
                        <img src="https://images.unsplash.com/photo-1606761568499-6d2451b23c66?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Kampus Pesantren" class="rounded-2xl shadow-lg w-full h-64 object-cover">
                    </div>
                    <!-- Decorative Element -->
                    <div class="absolute -z-10 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[110%] h-[110%] bg-brand-100 rounded-full blur-3xl opacity-50"></div>
                </div>

                <!-- Text Content -->
                <div class="fade-in-up" style="transition-delay: 0.2s;">
                    <h4 class="text-brand-700 font-semibold uppercase tracking-wider text-sm mb-2">Tentang Kami</h4>
                    <h2 class="text-3xl md:text-4xl font-bold text-slate-800 mb-6 leading-tight">Tradisi Pesantren dalam <br><span class="text-brand-900">Kemasan Modern</span></h2>
                    <p class="text-slate-600 mb-6 leading-relaxed">
                        Pesantren Modern Al-Hikmah didirikan dengan visi mengintegrasikan ilmu agama (tafaqquh fiddin) dengan ilmu pengetahuan modern. Kami berkomitmen mencetak santri yang tidak hanya hafal Al-Qur'an, tetapi juga menguasai teknologi dan bahasa internasional.
                    </p>
                    
                    <ul class="space-y-4 mb-8">
                        <li class="flex items-start gap-3">
                            <div class="mt-1 bg-brand-100 text-brand-700 p-1 rounded-full"><i class="fa-solid fa-check text-xs"></i></div>
                            <span class="text-slate-700">Kurikulum terpadu (Kemenag & Kemendikbud)</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <div class="mt-1 bg-brand-100 text-brand-700 p-1 rounded-full"><i class="fa-solid fa-check text-xs"></i></div>
                            <span class="text-slate-700">Fasilitas modern dan asrama yang nyaman</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <div class="mt-1 bg-brand-100 text-brand-700 p-1 rounded-full"><i class="fa-solid fa-check text-xs"></i></div>
                            <span class="text-slate-700">Tenaga pengajar profesional dan lulusan Timur Tengah</span>
                        </li>
                    </ul>

                    <!-- Stats -->
                    <div class="grid grid-cols-3 gap-6 pt-6 border-t border-slate-200">
                        <div>
                            <h3 class="text-3xl font-bold text-brand-900">25+</h3>
                            <p class="text-sm text-slate-500 mt-1">Tahun Pengalaman</p>
                        </div>
                        <div>
                            <h3 class="text-3xl font-bold text-brand-900">1.2K</h3>
                            <p class="text-sm text-slate-500 mt-1">Santri Aktif</p>
                        </div>
                        <div>
                            <h3 class="text-3xl font-bold text-brand-900">5K+</h3>
                            <p class="text-sm text-slate-500 mt-1">Alumni Tersebar</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Program Pendidikan -->
    <section id="program" class="py-20 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center max-w-3xl mx-auto mb-16 fade-in-up">
                <h4 class="text-brand-700 font-semibold uppercase tracking-wider text-sm mb-2">Program Unggulan</h4>
                <h2 class="text-3xl md:text-4xl font-bold text-slate-800 mb-4">Pendidikan Komprehensif</h2>
                <p class="text-slate-600">Beragam program dirancang untuk mengembangkan potensi kognitif, afektif, dan spiritual santri secara seimbang.</p>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
                <!-- Program 1 -->
                <div class="bg-slate-50 rounded-2xl p-8 hover:bg-brand-900 hover:text-white transition-all duration-300 group shadow-sm hover:shadow-xl fade-in-up">
                    <div class="w-14 h-14 bg-white rounded-xl shadow-sm flex items-center justify-center text-brand-700 text-2xl mb-6 group-hover:scale-110 transition-transform">
                        <i class="fa-solid fa-book-open-reader"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-3 text-slate-800 group-hover:text-white">Pendidikan Formal</h3>
                    <p class="text-slate-600 group-hover:text-brand-100 text-sm leading-relaxed mb-4">
                        Tingkat SMP dan SMA dengan kurikulum nasional yang diperkaya dengan muatan lokal kepesantrenan.
                    </p>
                    <a href="#" class="inline-flex items-center text-sm font-medium text-brand-700 group-hover:text-gold-400">
                        Pelajari detail <i class="fa-solid fa-arrow-right ml-2 text-xs"></i>
                    </a>
                </div>

                <!-- Program 2 -->
                <div class="bg-slate-50 rounded-2xl p-8 hover:bg-brand-900 hover:text-white transition-all duration-300 group shadow-sm hover:shadow-xl fade-in-up" style="transition-delay: 0.1s;">
                    <div class="w-14 h-14 bg-white rounded-xl shadow-sm flex items-center justify-center text-brand-700 text-2xl mb-6 group-hover:scale-110 transition-transform">
                        <i class="fa-solid fa-quran"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-3 text-slate-800 group-hover:text-white">Tahfidz Qur'an</h3>
                    <p class="text-slate-600 group-hover:text-brand-100 text-sm leading-relaxed mb-4">
                        Program hafalan Al-Qur'an terstruktur dengan target mutqin 30 Juz serta pemahaman tafsir dasar.
                    </p>
                    <a href="#" class="inline-flex items-center text-sm font-medium text-brand-700 group-hover:text-gold-400">
                        Pelajari detail <i class="fa-solid fa-arrow-right ml-2 text-xs"></i>
                    </a>
                </div>

                <!-- Program 3 -->
                <div class="bg-slate-50 rounded-2xl p-8 hover:bg-brand-900 hover:text-white transition-all duration-300 group shadow-sm hover:shadow-xl fade-in-up" style="transition-delay: 0.2s;">
                    <div class="w-14 h-14 bg-white rounded-xl shadow-sm flex items-center justify-center text-brand-700 text-2xl mb-6 group-hover:scale-110 transition-transform">
                        <i class="fa-solid fa-language"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-3 text-slate-800 group-hover:text-white">Bilingual System</h3>
                    <p class="text-slate-600 group-hover:text-brand-100 text-sm leading-relaxed mb-4">
                        Kewajiban berbahasa Arab dan Inggris dalam percakapan sehari-hari di lingkungan asrama.
                    </p>
                    <a href="#" class="inline-flex items-center text-sm font-medium text-brand-700 group-hover:text-gold-400">
                        Pelajari detail <i class="fa-solid fa-arrow-right ml-2 text-xs"></i>
                    </a>
                </div>

                <!-- Program 4 -->
                <div class="bg-slate-50 rounded-2xl p-8 hover:bg-brand-900 hover:text-white transition-all duration-300 group shadow-sm hover:shadow-xl fade-in-up" style="transition-delay: 0.3s;">
                    <div class="w-14 h-14 bg-white rounded-xl shadow-sm flex items-center justify-center text-brand-700 text-2xl mb-6 group-hover:scale-110 transition-transform">
                        <i class="fa-solid fa-laptop-code"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-3 text-slate-800 group-hover:text-white">Ekstrakurikuler IT</h3>
                    <p class="text-slate-600 group-hover:text-brand-100 text-sm leading-relaxed mb-4">
                        Pelatihan coding, desain grafis, dan multimedia untuk membekali santri menghadapi era digital.
                    </p>
                    <a href="#" class="inline-flex items-center text-sm font-medium text-brand-700 group-hover:text-gold-400">
                        Pelajari detail <i class="fa-solid fa-arrow-right ml-2 text-xs"></i>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Fasilitas -->
    <section id="fasilitas" class="py-20 bg-brand-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-col md:flex-row justify-between items-end mb-12 fade-in-up">
                <div class="max-w-2xl">
                    <h4 class="text-brand-700 font-semibold uppercase tracking-wider text-sm mb-2">Fasilitas Kampus</h4>
                    <h2 class="text-3xl md:text-4xl font-bold text-slate-800 leading-tight">Lingkungan Belajar yang <br>Nyaman & Representatif</h2>
                </div>
                <div class="mt-6 md:mt-0">
                    <button class="px-6 py-2 border-2 border-brand-900 text-brand-900 font-medium rounded-full hover:bg-brand-900 hover:text-white transition-colors">
                        Lihat Semua Fasilitas
                    </button>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <!-- Fasilitas 1 -->
                <div class="group relative rounded-2xl overflow-hidden shadow-lg aspect-[4/3] fade-in-up">
                    <img src="https://images.unsplash.com/photo-1564683214965-3619addd900d?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Masjid Jami'" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                    <div class="absolute inset-0 bg-gradient-to-t from-slate-900/90 via-slate-900/40 to-transparent"></div>
                    <div class="absolute bottom-0 left-0 p-6">
                        <div class="bg-brand-500 text-white text-xs font-bold px-3 py-1 rounded-full inline-block mb-3">Pusat Kegiatan</div>
                        <h3 class="text-xl font-bold text-white mb-1">Masjid Jami' Al-Hikmah</h3>
                        <p class="text-slate-300 text-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300 transform translate-y-2 group-hover:translate-y-0">Kapasitas 2000 jamaah dengan arsitektur menawan.</p>
                    </div>
                </div>

                <!-- Fasilitas 2 -->
                <div class="group relative rounded-2xl overflow-hidden shadow-lg aspect-[4/3] fade-in-up" style="transition-delay: 0.1s;">
                    <img src="https://images.unsplash.com/photo-1562774053-701939374585?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Perpustakaan" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                    <div class="absolute inset-0 bg-gradient-to-t from-slate-900/90 via-slate-900/40 to-transparent"></div>
                    <div class="absolute bottom-0 left-0 p-6">
                        <div class="bg-gold-500 text-white text-xs font-bold px-3 py-1 rounded-full inline-block mb-3">Literasi</div>
                        <h3 class="text-xl font-bold text-white mb-1">Perpustakaan Digital</h3>
                        <p class="text-slate-300 text-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300 transform translate-y-2 group-hover:translate-y-0">Koleksi kitab kuning dan buku modern yang lengkap.</p>
                    </div>
                </div>

                <!-- Fasilitas 3 -->
                <div class="group relative rounded-2xl overflow-hidden shadow-lg aspect-[4/3] fade-in-up" style="transition-delay: 0.2s;">
                    <img src="https://images.unsplash.com/photo-1555854877-bab0e564b8d5?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Asrama Santri" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                    <div class="absolute inset-0 bg-gradient-to-t from-slate-900/90 via-slate-900/40 to-transparent"></div>
                    <div class="absolute bottom-0 left-0 p-6">
                        <div class="bg-blue-500 text-white text-xs font-bold px-3 py-1 rounded-full inline-block mb-3">Tempat Tinggal</div>
                        <h3 class="text-xl font-bold text-white mb-1">Asrama Ber-AC</h3>
                        <p class="text-slate-300 text-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300 transform translate-y-2 group-hover:translate-y-0">Fasilitas hunian yang bersih, nyaman, dan terawasi 24 jam.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Berita & Informasi Section -->
    <section id="berita" class="py-20 bg-slate-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-col md:flex-row justify-between items-end mb-12 fade-in-up">
                <div class="max-w-2xl">
                    <h4 class="text-brand-700 font-semibold uppercase tracking-wider text-sm mb-2">Informasi Terkini</h4>
                    <h2 class="text-3xl md:text-4xl font-bold text-slate-800 leading-tight">Berita & Kegiatan <br>Pesantren</h2>
                </div>
                <div class="mt-6 md:mt-0">
                    <button class="px-6 py-2 text-brand-900 font-medium hover:text-brand-700 transition-colors flex items-center gap-2">
                        Lihat Semua Berita <i class="fa-solid fa-arrow-right"></i>
                    </button>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- Berita 1 -->
                <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-shadow duration-300 fade-in-up">
                    <img src="https://images.unsplash.com/photo-1523050854058-8df90110c9f1?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Wisuda Santri" class="w-full h-48 object-cover">
                    <div class="p-6">
                        <div class="flex items-center gap-3 text-xs text-slate-500 mb-3">
                            <span><i class="fa-regular fa-calendar mr-1"></i> 10 Jun 2026</span>
                            <span><i class="fa-regular fa-folder mr-1"></i> Akademik</span>
                        </div>
                        <h3 class="text-lg font-bold text-slate-800 mb-2 line-clamp-2 hover:text-brand-700 transition-colors cursor-pointer">Haflah Akhirussanah dan Wisuda Tahfidz Angkatan Ke-15</h3>
                        <p class="text-slate-600 text-sm mb-4 line-clamp-3">Alhamdulillah, telah terlaksana dengan khidmat acara perpisahan dan wisuda bagi santri kelas akhir yang telah menyelesaikan hafalan 30 juz.</p>
                        <a href="#" class="text-brand-700 font-medium text-sm hover:text-brand-900">Baca selengkapnya &rarr;</a>
                    </div>
                </div>

                <!-- Berita 2 -->
                <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-shadow duration-300 fade-in-up" style="transition-delay: 0.1s;">
                    <img src="https://images.unsplash.com/photo-1584697964400-2af6a2f6204c?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Kunjungan Syeikh" class="w-full h-48 object-cover">
                    <div class="p-6">
                        <div class="flex items-center gap-3 text-xs text-slate-500 mb-3">
                            <span><i class="fa-regular fa-calendar mr-1"></i> 05 Jun 2026</span>
                            <span><i class="fa-regular fa-folder mr-1"></i> Kegiatan</span>
                        </div>
                        <h3 class="text-lg font-bold text-slate-800 mb-2 line-clamp-2 hover:text-brand-700 transition-colors cursor-pointer">Kunjungan Syeikh dari Universitas Al-Azhar Kairo</h3>
                        <p class="text-slate-600 text-sm mb-4 line-clamp-3">Pesantren Modern Al-Hikmah menerima kunjungan kehormatan untuk memberikan studium generale kepada seluruh santri dan asatidz.</p>
