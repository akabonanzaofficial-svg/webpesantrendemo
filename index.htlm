        </main>

        <!-- Modal Tulis Berita -->
        <div id="form-berita-modal" class="hidden absolute inset-0 z-[120] bg-slate-900/60 backdrop-blur-sm flex items-center justify-center p-4">
            <div class="bg-white rounded-3xl shadow-2xl w-full max-w-4xl max-h-[90vh] flex flex-col animate-[fadeInUp_0.3s_ease-out]">
                <div class="p-6 border-b border-slate-100 flex justify-between items-center bg-slate-50/50 rounded-t-3xl">
                    <h3 class="text-xl font-bold text-slate-800 flex items-center gap-2"><i class="fa-solid fa-pen-nib text-brand-600"></i> Editor Berita</h3>
                    <button onclick="document.getElementById('form-berita-modal').classList.add('hidden')" class="w-8 h-8 flex items-center justify-center rounded-full text-slate-400 hover:bg-slate-200 hover:text-slate-700 transition-colors"><i class="fa-solid fa-xmark text-lg"></i></button>
                </div>
                
                <div class="p-6 overflow-y-auto flex-1 space-y-5">
                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-1">Judul Berita</label>
                        <input type="text" placeholder="Masukkan judul yang menarik..." class="w-full border border-slate-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-brand-500 outline-none font-medium text-slate-800">
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div>
                            <label class="block text-sm font-semibold text-slate-700 mb-1">Kategori</label>
                            <select class="w-full border border-slate-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-brand-500 outline-none bg-white text-sm">
                                <option>Akademik</option>
                                <option>Kegiatan</option>
                                <option>Prestasi</option>
                                <option>Pengumuman</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-slate-700 mb-1">Tanggal Publikasi</label>
                            <input type="date" class="w-full border border-slate-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-brand-500 outline-none text-sm">
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-1">URL Gambar Thumbnail</label>
                        <input type="text" placeholder="https://images.unsplash.com/..." class="w-full border border-slate-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-brand-500 outline-none text-sm text-blue-600">
                        <p class="text-xs text-slate-500 mt-1">Masukkan link gambar (unsplash/imgur/drive).</p>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-1">Isi Konten Berita</label>
                        <textarea rows="8" placeholder="Tulis isi selengkapnya di sini..." class="w-full border border-slate-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-brand-500 outline-none text-sm leading-relaxed"></textarea>
                    </div>
                </div>
                
                <div class="p-6 border-t border-slate-100 flex justify-end gap-3 bg-slate-50 rounded-b-3xl">
                    <button onclick="document.getElementById('form-berita-modal').classList.add('hidden')" class="px-6 py-2.5 border border-slate-300 text-slate-600 font-bold rounded-xl hover:bg-white hover:shadow-sm transition-all">Batal</button>
                    <button onclick="document.getElementById('form-berita-modal').classList.add('hidden')" class="px-6 py-2.5 bg-brand-900 text-white font-bold rounded-xl hover:bg-brand-700 transition-colors shadow-lg shadow-brand-900/20 flex items-center gap-2">
                        <i class="fa-solid fa-paper-plane text-sm"></i> Simpan & Publikasikan
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Tambahan animasi simpel untuk CMS -->
    <style>
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    </style>

    <script>
        // Mobile Menu Toggle Logic
        const btn = document.getElementById('mobile-menu-btn');
        const menu = document.getElementById('mobile-menu');

        btn.addEventListener('click', () => {
            menu.classList.toggle('hidden');
        });

        // Close mobile menu when a link is clicked
        const mobileLinks = menu.querySelectorAll('a');
        mobileLinks.forEach(link => {
            link.addEventListener('click', () => {
                menu.classList.add('hidden');
            });
        });

        // Navbar Scroll Effect
        const navbar = document.getElementById('navbar');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 20) {
                navbar.classList.add('shadow-md');
                navbar.classList.replace('glass-nav', 'bg-white');
            } else {
                navbar.classList.remove('shadow-md');
                navbar.classList.replace('bg-white', 'glass-nav');
            }
        });

        // Intersection Observer for Scroll Animations
        const observerOptions = {
            root: null,
            rootMargin: '0px',
            threshold: 0.15
        };

        const observer = new IntersectionObserver((entries, observer) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                    observer.unobserve(entry.target); // Stop observing once animated
                }
            });
        }, observerOptions);

        // Target all elements with .fade-in-up class
        document.querySelectorAll('.fade-in-up').forEach((el) => {
            observer.observe(el);
        });

        // ==========================================
        // LOGIKA SISTEM CMS & ROUTING
        // ==========================================
        const adminView = document.getElementById('admin-view');
        const loginScreen = document.getElementById('cms-login-screen');
        const loginForm = document.getElementById('login-form');
        const closeCmsBtn = document.getElementById('close-cms-btn');

        // Fungsi mengecek URL apakah mengandung #admin
        function checkAdminRoute() {
            if (window.location.hash === '#admin') {
                adminView.classList.remove('hidden');
                document.body.style.overflow = 'hidden'; // Matikan scroll web utama
                // Reset layar ke login jika belum login (simulasi)
                loginScreen.classList.remove('hidden');
            } else {
                adminView.classList.add('hidden');
                document.body.style.overflow = 'auto'; // Nyalakan scroll web utama
            }
        }

        // Jalankan pengecekan saat url hash berubah dan saat web pertama dimuat
        window.addEventListener('hashchange', checkAdminRoute);
        if (window.location.hash === '#admin') checkAdminRoute();

        // Tombol kembali ke web publik
        closeCmsBtn.addEventListener('click', (e) => {
            e.preventDefault();
            window.location.hash = ''; // Hapus #admin dari URL
        });

        // Handle Simulasi Login
        loginForm.addEventListener('submit', (e) => {
            e.preventDefault();
            // Nanti dikembangkan untuk memvalidasi password ke Google Script API
            const pwd = document.getElementById('admin-password').value;
            if(pwd.trim() !== "") {
                loginScreen.classList.add('hidden'); // Sembunyikan layar login
            }
        });

        // Handle Simulasi Logout
        function logoutCMS() {
            loginScreen.classList.remove('hidden');
            document.getElementById('admin-password').value = '';
        }

        // Logika Perpindahan Tab Menu CMS
        function switchTab(tabId) {
            // Sembunyikan semua tab
            document.querySelectorAll('.cms-tab-content').forEach(tab => {
                tab.classList.remove('block');
                tab.classList.add('hidden');
            });
            // Tampilkan tab yang dipilih
            document.getElementById(tabId).classList.remove('hidden');
            document.getElementById(tabId).classList.add('block');

            // Update warna tombol navigasi sidebar
            document.querySelectorAll('.cms-nav-btn').forEach(btn => {
                btn.classList.remove('bg-brand-900', 'text-white', 'shadow-md');
                btn.classList.add('text-slate-400');
            });
            const activeBtn = document.getElementById('nav-' + tabId);
            if (activeBtn) {
                activeBtn.classList.remove('text-slate-400');
                activeBtn.classList.add('bg-brand-900', 'text-white', 'shadow-md');
            }

            // Tutup sidebar di versi Mobile jika terbuka
            const sidebar = document.getElementById('cms-sidebar');
            if (window.innerWidth < 768 && !sidebar.classList.contains('hidden')) {
                sidebar.classList.add('hidden');
            }
        }

        // Tombol Hamburger Menu CMS Mobile
        document.getElementById('mobile-cms-menu-btn').addEventListener('click', () => {
            const sidebar = document.getElementById('cms-sidebar');
            sidebar.classList.toggle('hidden');
            sidebar.classList.add('absolute', 'z-50', 'w-64', 'h-full', 'shadow-2xl');
        });

    </script>
</body>
</html>
```

### Cara Membuka Panel CMS ini:
1. Pastikan kode di atas sudah diterapkan dan dirender oleh sistem.
2. Di lingkungan kolaboratif (Immersive) ini, klik tab **Browser** atau jika Anda membuka preview web ini di tab baru, lihat kolom URL Address Bar.
3. Tambahkan teks **`#admin`** tepat di belakang URL (contoh: `.../index.html#admin`), lalu tekan Enter.
4. Jendela **Login CMS Al-Hikmah** akan langsung muncul menutupi layar! Ketik password apa saja (karena ini masih desain) dan tekan tombol Masuk.

Silakan eksplorasi desain form-form pengaturannya. Jika menurut Anda antarmukanya sudah elegan dan pas, langkah selanjutnya kita akan berpindah membuat skrip backend (Google Apps Script). Bagaimana menurut Anda tampilannya?
